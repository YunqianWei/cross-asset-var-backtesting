data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# Large or generated files
*.csv
*.xlsx
*.parquet
*.pkl
*.joblib
*.sqlite
*.db

# System files
.DS_Store
Thumbs.db

# Logs
*.log
# Word documents
*.docx
